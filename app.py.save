from flask import Flask, request, json|ify
from openai import OpenAI

app = Flask(__name__)

client = OpenAI(api_key="PASTE_YOUR_NEW_API_KEY_HERE")

@app.route('/')
def home():
    return "ViralForge API is running 🚀"

@app.route('/generate')
def generate():
    niche = request.args.get('niche', 'business')

    prompt = f"""
    Generate a viral short-form video idea in the {niche} niche.

    Include:
    - Hook (very attention grabbing)
    - Content idea
    - Caption
    """

    response = client.chat.completions.create(
        model="gpt-4.1-mini",
        messages=[{"role": "user", "content": prompt}]
    )

  
